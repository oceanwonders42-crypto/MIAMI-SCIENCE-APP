# =============================================================================
# Miami Science Tracker — environment variables
# Copy to .env.local and fill in values. Never commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for auth, RLS, and most app data)
# Where: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
# Public project URL. Example: https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# anon (public) key — safe to expose in the browser; used by client + server.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — SERVER ONLY. Required for: WooCommerce webhooks, admin sync,
# cron jobs, and any server code that bypasses RLS. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Public app URL (recommended in production)
# Used for: email template links, unsubscribe URLs, affiliate referral base,
# Capacitor fallback, password reset redirect (if NEXT_PUBLIC_SITE_URL unset).
# Format: https://your-domain.com — no trailing slash
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=

# Primary Site URL for Supabase Auth email redirects (password recovery).
# If unset, password-reset.ts falls back to NEXT_PUBLIC_APP_URL.
# Must match Supabase → Authentication → URL Configuration (Site URL + Redirect URLs).
NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------------------------------------
# Miami Science store — public links (mia-science.com WooCommerce storefront)
# Optional: defaults to https://mia-science.com when unset (see src/lib/constants.ts)
# -----------------------------------------------------------------------------
# Canonical store origin for shop/refill links in the app.
NEXT_PUBLIC_STORE_URL=https://mia-science.com

# Legacy/alternate public store URL (used if NEXT_PUBLIC_STORE_URL is unset).
NEXT_PUBLIC_SHOP_REFILL_URL=

# Full URL to the customer “My account → Orders” page (optional).
# Default: {NEXT_PUBLIC_STORE_URL or SHOP_REFILL_URL}/my-account/orders
NEXT_PUBLIC_STORE_ORDERS_URL=

# -----------------------------------------------------------------------------
# WooCommerce REST API (products, orders, customers — server-side sync)
# Where: WordPress admin → WooCommerce → Settings → Advanced → REST API → Add key
# Permissions: Read (or Read/Write if you create orders from the app).
# Base URL should match the store (e.g. https://mia-science.com), no trailing slash.
# -----------------------------------------------------------------------------
WOOCOMMERCE_URL=https://mia-science.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# -----------------------------------------------------------------------------
# WooCommerce webhooks (order + shipment → /api/webhooks/store/*)
# Where: WooCommerce → Settings → Advanced → Webhooks
#   - Order updated → https://<your-app>/api/webhooks/store/order
#   - (Optional) Shipment/custom topic as you configured → .../shipment
# Secret must match the webhook’s signing secret; verified via X-WC-Webhook-Signature (HMAC-SHA256, base64).
# -----------------------------------------------------------------------------
# Set to "true" to accept webhooks (503 if false).
STORE_SYNC_ENABLED=false
WOOCOMMERCE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# SliceWP (affiliate stats / referral sync via WordPress REST)
# Where: SliceWP docs — REST API with Application Password or consumer key/secret as configured on the WP site.
# Set SLICEWP_SYNC_ENABLED=true only when URL + key + secret are set.
# SLICEWP_API_URL: site root (https://mia-science.com) OR full base including /wp-json/slicewp/v1
# -----------------------------------------------------------------------------
SLICEWP_SYNC_ENABLED=false
SLICEWP_API_URL=https://mia-science.com
SLICEWP_CONSUMER_KEY=
SLICEWP_CONSUMER_SECRET=

# -----------------------------------------------------------------------------
# ShipStation (shipment / tracking sync — server-only)
# Where: ShipStation → Account → API Settings → API Keys (v2 uses API Key in header)
# -----------------------------------------------------------------------------
SHIPSTATION_API_KEY=
# Optional. Default in code: https://api.shipstation.com
SHIPSTATION_BASE_URL=

# -----------------------------------------------------------------------------
# Square (invoices / orders — server-only)
# Where: Square Developer Dashboard → Applications → Credentials
# -----------------------------------------------------------------------------
SQUARE_ACCESS_TOKEN=
# "sandbox" or "production" (anything other than sandbox selects production).
SQUARE_ENVIRONMENT=production
# Optional; used when fetching orders by ID without an explicit location_id.
SQUARE_LOCATION_ID=

# -----------------------------------------------------------------------------
# Email (Resend)
# Where: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# Verified sender in Resend, e.g. notifications@yourdomain.com
EMAIL_FROM=notifications@mia-science.com

# -----------------------------------------------------------------------------
# Apple Push Notification service (iOS) — server-only, used by notification cron
# Where: Apple Developer → Certificates, Identifiers & Profiles → Keys → APNs Auth Key
# APNS_PRIVATE_KEY: full .p8 contents, or use \n for newlines in a single line.
# -----------------------------------------------------------------------------
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
# Defaults to com.miascience.tracker if unset
APNS_BUNDLE_ID=com.miascience.tracker
# "true" or "1" for production APNs (App Store / TestFlight)
APNS_PRODUCTION=false

# -----------------------------------------------------------------------------
# Cron: /api/cron/notifications (scheduled email + push)
# Auth: Authorization: Bearer <secret> OR ?secret=<secret> (GET or POST)
# Use one variable; NOTIFICATION_CRON_SECRET is preferred if both exist.
# -----------------------------------------------------------------------------
NOTIFICATION_CRON_SECRET=
# Alias (optional): if NOTIFICATION_CRON_SECRET is empty, CRON_SECRET is used.
CRON_SECRET=

# -----------------------------------------------------------------------------
# iOS / Capacitor
# -----------------------------------------------------------------------------
# When true, hides Admin entry points in customer nav (App Store build).
NEXT_PUBLIC_APP_STORE_BUILD=false

# Comma-separated hostnames (no scheme/port) that may open /admin in production even when
# NEXT_PUBLIC_APP_STORE_BUILD=true (operator domain on the same Vercel project). Example:
# NEXT_PUBLIC_ADMIN_WEB_HOSTS=ops.app.mia-science.com
# Public app hostname must NOT be listed — /admin stays blocked for Capacitor users.
NEXT_PUBLIC_ADMIN_WEB_HOSTS=

# URL the native shell loads. Local dev: http://localhost:3000
# Falls back to NEXT_PUBLIC_APP_URL then https://app.mia-science.com
CAPACITOR_SERVER_URL=

# -----------------------------------------------------------------------------
# AI exercise images (admin — generate library photos)
# IMAGE_GENERATION_PROVIDER: openai | stability | replicate
# OpenAI: DALL·E 3 (returns hosted URL). If IMAGE_GENERATION_API_KEY is empty, OPENAI_API_KEY is used.
# Stability: uploads PNG to Supabase exercise-images bucket.
# Replicate: default model flux-schnell; override with IMAGE_GENERATION_REPLICATE_MODEL=owner/name
# -----------------------------------------------------------------------------
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_PROVIDER=openai
# Optional fallback when provider is openai (same as many other OpenAI integrations)
# OPENAI_API_KEY=
# IMAGE_GENERATION_REPLICATE_MODEL=black-forest-labs/flux-schnell

# -----------------------------------------------------------------------------
# Development only
# -----------------------------------------------------------------------------
# Show “Add demo data” on Orders page (only when NODE_ENV=development).
NEXT_PUBLIC_ALLOW_DEMO_SEED=false
